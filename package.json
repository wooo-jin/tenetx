{
  "name": "tenetx",
  "version": "2.1.0",
  "main": "dist/cli.js",
  "types": "./dist/cli.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "link": "npm run build && npm link",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "format": "biome format --write src/",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "author": "jang-ujin",
  "license": "MIT",
  "description": "The AI coding tool that adapts to you — personalized harness for Claude Code",
  "keywords": [
    "claude-code",
    "tenetx",
    "personalization",
    "ai-harness",
    "workflow",
    "ai-agent",
    "forge",
    "compound-engineering"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wooo-jin/tenetx.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "bin": {
    "tenetx": "./dist/cli.js",
    "txd": "./dist/txd.js"
  },
  "files": [
    "dist/",
    "agents/",
    "skills/",
    "packs/",
    "templates/",
    "plugin.json",
    "README.md",
    "README.ko.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.28",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "ink": "^5.2.1",
    "js-yaml": "^4.1.1",
    "react": "^18.3.1"
  }
}
