{
  "$schema": "https://claude.ai/schemas/claude-plugin.json",
  "name": "tenetx",
  "version": "2.1.0",
  "description": "The AI coding tool that adapts to you — personalized harness for Claude Code",
  "author": "jang-ujin",
  "license": "MIT",
  "homepage": "https://github.com/wooo-jin/tenetx",
  "keywords": [
    "claude-code",
    "harness",
    "personalization",
    "ai-harness",
    "forge"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/keyword-detector.js\"",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/skill-injector.js\"",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/context-guard.js\"",
            "timeout": 2000
          },
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/solution-injector.js\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/session-recovery.js\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/context-guard.js\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/pre-tool-use.js\"",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/db-guard.js\"",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/rate-limiter.js\"",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/post-tool-use.js\"",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/secret-filter.js\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/subagent-tracker.js\" start",
            "timeout": 2000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/subagent-tracker.js\" stop",
            "timeout": 2000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/pre-compact.js\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/permission-handler.js\"",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_DIR}/dist/hooks/post-tool-failure.js\"",
            "timeout": 3000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "tenetx status"
  },
  "agents": "agents/",
  "skills": "skills/"
}
