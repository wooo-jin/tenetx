FROM node:22-slim

RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*

# Claude Code CLI (non-critical if fails)
RUN npm i -g @anthropic-ai/claude-code@latest 2>/dev/null || echo "Claude CLI optional"

WORKDIR /workspace

# tenetx 소스에서 직접 빌드 + 설치
COPY . /workspace/tenetx-src
RUN cd /workspace/tenetx-src && npm ci && npm run build && npm pack && \
    npm i -g /workspace/tenetx-src/tenetx-*.tgz

# 검증 스크립트
COPY tests/e2e/docker/verify-v1.sh /workspace/verify-v1.sh
RUN chmod +x /workspace/verify-v1.sh

# 테스트 프로젝트
RUN mkdir -p /workspace/test-project && \
    cd /workspace/test-project && \
    git init && git config user.email "test@test.com" && git config user.name "test" && \
    npm init -y

WORKDIR /workspace/test-project

ENTRYPOINT ["/workspace/verify-v1.sh"]
